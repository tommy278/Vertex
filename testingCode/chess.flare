fnc printunderscores(count:int):void{
	var it:int = 0;
	while (it < count + 2)
	{
		it = it + 1;
		write!("_");
	}
	writeLn!("");
}

const size:int = 10;
printunderscores(size);
var it:int = 0;

while (it < size)
{
	write!("|");
	it = it + 1;
	var it2:int = 0;
	while (it2 < size)
	{
		var rem:int = 0;
		var rem2:int = 0;
		var tile:string = "X";
		it2 = it2 + 1;
		rem = it % 2;
		rem2 = (it2 + rem) % 2;
		if (rem2 > 0)
		{
			tile = " ";
		}
		write!(tile);
	}
	writeLn!("|");
}
printunderscores(size);
